# 컨테이너 이름 prefix
# 예: house (로컬), house-inventory (운영)
CONTAINER_PREFIX=house

# Docker network 이름
# 외부 공유 postgres가 같은 네트워크에 attach되어 있어야 한다.
NETWORK_NAME=house-net

# 호스트에서 노출할 프론트 포트
FRONT_PORT=8085

# DB 연결 (외부 공유 postgres 사용)
# DB_HOST는 같은 docker network에 있는 외부 postgres 컨테이너의 이름.
DB_HOST=postgres
DB_PORT=5432
DB_NAME=yangyag
DB_USER=house
DB_PASSWORD=replace-me
DB_SCHEMA=house

# CORS 허용 origin (콤마 구분, 공백 없이)
CORS_ALLOWED_ORIGINS=http://localhost:8085
